# --- Frontend Variables (Vite) ---
# The URL of your FastAPI backend. Use http://localhost:8000/api for local development.
VITE_API_URL=http://localhost:8000/api

# OpenAI API Key (if using OpenAI on the frontend directly, though backend is preferred)
VITE_OPENAI_API_KEY=your_openai_key_here

# --- Backend Variables (FastAPI) ---
# Project settings
PROJECT_NAME=LexiLearn
API_VERSION=v1
ENVIRONMENT=development

# Security
SECRET_KEY=generate_a_secure_random_string_here

# Database
# Use sqlite:///./lexilearn.db for local, or your RDS URL for production
DATABASE_URL=sqlite:///./lexilearn.db

# AWS Configuration (Required for Bedrock, S3, etc.)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
S3_BUCKET_NAME=lexilearn-uploads

# OpenAI (Fallback if Bedrock is not configured)
OPENAI_API_KEY=your_openai_key_here
