{
  "family": "lexilearn-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/lexilearn-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "lexilearn-backend",
      "image": "ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/lexilearn-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "ENVIRONMENT",       "value": "production" },
        { "name": "AWS_REGION",        "value": "us-east-1" },
        { "name": "BEDROCK_MODEL_ID",  "value": "us.amazon.nova-lite-v1:0" },
        { "name": "DYNAMODB_CACHE_TABLE", "value": "LexiLearn_AICache" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:lexilearn/database_url"
        },
        {
          "name": "SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:lexilearn/secret_key"
        },
        {
          "name": "S3_BUCKET_NAME",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:lexilearn/s3_bucket_name"
        },
        {
          "name": "FRONTEND_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:lexilearn/frontend_url"
        },
        {
          "name": "COGNITO_REGION",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:lexilearn/cognito_region"
        },
        {
          "name": "COGNITO_USER_POOL_ID",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:lexilearn/cognito_user_pool_id"
        },
        {
          "name": "COGNITO_APP_CLIENT_ID",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:lexilearn/cognito_app_client_id"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/lexilearn-backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8000/api/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
